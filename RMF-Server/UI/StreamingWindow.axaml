<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="RMF_Server.UI.StreamingWindow"
        Title="Simple-RMF Control Center"
        Width="100" Height="100">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="Black" Margin="5">
            <Image Source="{Binding DisplaySource}" Stretch="Uniform" />
        </Border>
    </Grid>

	<Window.Styles>
		<FluentTheme />
	</Window.Styles>
</Window>