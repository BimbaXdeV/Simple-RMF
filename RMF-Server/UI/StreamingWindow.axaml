<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="RMF_Server.UI.StreamingWindow"
        Title="Simple-RMF Control Center"
        Width="100" Height="100">

    <Grid>
        <Border Background="Black">
            <Image Source="{Binding DisplaySource}" Stretch="Uniform" />
        </Border>

		<Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Padding="8"
                Background="#AA000000"
                CornerRadius="4"
                IsHitTestVisible="False"
				IsVisible="{Binding IsOverlayEnabled}">

			<Grid ColumnDefinitions="Auto, 10, Auto" RowDefinitions="Auto, Auto">
				<TextBlock Grid.Row="0" Grid.Column="0" Text="FPS:" Foreground="#00FF00" FontSize="12" FontWeight="Bold"/>
				<TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding DisplayFps}" Foreground="White" FontSize="12"/>

				<TextBlock Grid.Row="1" Grid.Column="0" Text="FrameTime:" Foreground="#00FF00" FontSize="12" FontWeight="Bold"/>
				<TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding DisplayFrameTime, StringFormat=\{0\} ms}" Foreground="White" FontSize="12"/>
			</Grid>
		</Border>
    </Grid>

	<Window.Styles>
		<FluentTheme />
	</Window.Styles>
</Window>