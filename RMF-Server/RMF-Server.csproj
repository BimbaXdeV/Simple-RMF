<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net9.0</TargetFramework>
		<ApplicationIcon>Server.ico</ApplicationIcon>
		
		<RootNamespace>RMF_Server</RootNamespace>
		<LangVersion>latest</LangVersion>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup Condition="'$(RuntimeIdentifier)' == 'linux-x64'">
		<Content Include="Server.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="Avalonia" Version="11.3.12" />
	  <PackageReference Include="Avalonia.Desktop" Version="11.3.12" />
	  <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.12" />
	  <PackageReference Include="ReactiveUI.Avalonia" Version="11.4.12" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\RMF.Core\RMF.Core.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Update="Storage\commands.xml">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="Storage\config.xml">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="Storage\extpaths.xml">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="UI\StreamingWindow.axaml">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>
</Project>